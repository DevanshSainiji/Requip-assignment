# .env.test.example
#
# This is an example test environment configuration.
# Copy this file to .env.test and update the DATABASE_URL with valid
# credentials for a dedicated TEST database on your local machine.
#
# DO NOT POINT THIS AT YOUR DEVELOPMENT DATABASE.
# The test suite hard-deletes the `users` table before every test.

PORT=5001
NODE_ENV=test
DATABASE_URL="mysql://username:password@localhost:3306/requip_test_db"
CLIENT_URL=http://localhost:5173
