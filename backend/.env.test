# Test environment — points to a SEPARATE database so tests never touch dev data
#
# SETUP (run once before the first `npm test`):
#   1. Create the test database in MySQL:
#        mysql -u root -p -e "CREATE DATABASE IF NOT EXISTS requip_test_db;"
#   2. Apply schema migrations to the test DB:
#        npm run test:db:setup
#
# After that, `npm test` handles all cleanup automatically.

PORT=5001
NODE_ENV=test
DATABASE_URL="mysql://root:password@localhost:3306/requip_test_db"
CLIENT_URL=http://localhost:5173
